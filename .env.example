# Impact Calculator — канонический список переменных окружения
# Скопировать в .env.local (личный ПК) или research/.env (рабочий ПК)
# Значения из: docs/03_Firebase.md (Firebase) + docs/04_Vercel_Deploy.md (Vercel)
# .env.local и .env.* НИКОГДА не коммитить — заблокированы pre-commit hook

# ─── Firebase Web SDK (публичные — попадают в JS-бандл) ───────────────────────
# Источник: Firebase Console → Project Settings → Your apps → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=impact-calc-lp.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=impact-calc-lp
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=impact-calc-lp.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=33131969665
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (только серверный код — API routes) ────────────────────
# Источник: Firebase Console → Project Settings → Service accounts → Generate new private key
# Скопировать key-файл .json, затем взять client_email и private_key оттуда
# ВНИМАНИЕ: private key содержит \n как escape-последовательности, хранить как одну строку
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-fbsvc@impact-calc-lp.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Google Sheets API (тот же Service Account, что и Firebase Admin) ─────────
# Таблицу нужно расшарить на FIREBASE_ADMIN_CLIENT_EMAIL с доступом Viewer
GOOGLE_SHEETS_CLIENT_EMAIL=firebase-adminsdk-fbsvc@impact-calc-lp.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=103C2StHfJg9LPr9QFB4xmwkqLc_6pPoZT7_CKo3DuwE

# ─── Только для рабочего ПК (research/.env) ────────────────────────────────────
# Параметры подключения к корпоративной БД Greenplum (через Cisco VPN)
# Получать у администратора БД, НЕ хранить в основном .env.local
# GP_HOST=<corp_host>
# GP_PORT=5432
# GP_DATABASE=<db_name>
# GP_USER=<username>
# GP_PASSWORD=<password>
