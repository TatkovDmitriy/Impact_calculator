# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.example и .env.*.example можно коммитить
.env*
!.env.example
!.env.*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# secrets (belt + suspenders)
*.key
*firebase-admin*.json
*service-account*.json
*-private-key.json

# research — скрипты трекаются, секреты и артефакты нет
/research/.env
/research/output/
/research/notebooks/

# ops/_outbox — Path B fallback: JSON data files коммитятся (без секретов)
# .gitkeep коммитится, *.json тоже (они содержат только аналитику)
# Исключений не нужно — ops/ целиком трекается

# python
.venv/
__pycache__/
*.pyc
*.pyo

# test artifacts
/test-results/
/tests/e2e/report/

# OS
Thumbs.db
