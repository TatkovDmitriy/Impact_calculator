#!/usr/bin/env bash
# ops/hooks/pre-commit — защита от случайного коммита секретов и больших файлов
#
# Активировать однократно на каждой машине:
#   git config core.hooksPath ops/hooks
#
# Блокирует:
#   - .env.local, .env.production, .env.development (и другие .env.* кроме *.example)
#   - *firebase-admin*.json, *service-account*.json, *-private-key.json
#   - *.key файлы
#   - Файлы > 5MB

set -e

BLOCKED=0
STAGED_FILES=$(git diff --cached --name-only)

# Паттерны секретных файлов (regex для grep -E)
SECRET_PATTERNS=(
    '(^|/)\.env\.(local|production|development|staging|test)$'
    '(^|/)\.env$'
    'firebase-admin.*\.json'
    'service-account.*\.json'
    '-private-key\.json$'
    '\.key$'
)

for FILE in $STAGED_FILES; do
    # Пропустить удалённые файлы (они не несут риска)
    if ! git ls-files --error-unmatch "$FILE" > /dev/null 2>&1; then
        continue
    fi

    # Проверка на секретные паттерны
    for PATTERN in "${SECRET_PATTERNS[@]}"; do
        if echo "$FILE" | grep -qE "$PATTERN"; then
            echo "❌  BLOCKED (secret file): $FILE"
            echo "    Pattern matched: $PATTERN"
            BLOCKED=1
            break
        fi
    done

    # Проверка размера файла (> 5MB = 5242880 bytes)
    if [ -f "$FILE" ]; then
        FILE_SIZE=$(wc -c < "$FILE" 2>/dev/null || echo 0)
        if [ "$FILE_SIZE" -gt 5242880 ]; then
            SIZE_MB=$(echo "scale=1; $FILE_SIZE / 1048576" | bc 2>/dev/null || echo "?")
            echo "❌  BLOCKED (file too large, ${SIZE_MB}MB > 5MB): $FILE"
            BLOCKED=1
        fi
    fi
done

if [ "$BLOCKED" -eq 1 ]; then
    echo ""
    echo "Commit blocked. Remove the flagged files from staging:"
    echo "  git reset HEAD <file>"
    echo ""
    echo "To permanently ignore: add to .gitignore, then git rm --cached <file>"
    exit 1
fi

exit 0
